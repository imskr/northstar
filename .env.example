# Northstar — local development environment template
# Copy this file to .env and fill in the values you need.
# The dev server (make dev / scripts/dev.py) loads .env automatically.
# Variables marked [Render] are generated/set by Render in production.

# ── Session security [Render: generated automatically] ───────────────────────
# Any random string works locally; use a strong secret in production.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Leave both blank to use a local SQLite file at data/northstar.db (default).
# Set both to use Turso cloud instead.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Override the local SQLite path (optional):
# NORTHSTAR_DB_PATH=data/northstar.db

# ── Market data ───────────────────────────────────────────────────────────────
# Without a key, Northstar falls back to Stooq + Yahoo Finance (delayed quotes).
# Get a free key at https://twelvedata.com to enable real-time pricing.
# TWELVE_DATA_API_KEY=your-twelve-data-api-key

# ── Cookie security ───────────────────────────────────────────────────────────
# Set to true only when the app is served over HTTPS.
COOKIE_SECURE=false

# ── Registration ──────────────────────────────────────────────────────────────
# Set to false to lock the app to existing accounts only.
ALLOW_REGISTRATION=true

# ── Market data cache tuning (optional) ──────────────────────────────────────
# MARKET_QUOTE_CACHE_SECONDS=300
# MARKET_HISTORY_CACHE_SECONDS=21600
# MARKET_STALE_CACHE_SECONDS=172800
# MARKET_MIN_REQUEST_INTERVAL=0.45

# ── Database timeout (optional) ──────────────────────────────────────────────
# DATABASE_TIMEOUT_SECONDS=12
